# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Model selection ───────────────────────────────────────
# gpt-4o-mini is the best cost/quality balance for real-time use
OPENAI_MODEL=gpt-4o-mini

# ── TARS personality defaults ────────────────────────────
# All values 0-100
# TARS_HUMOR=70
# TARS_HONESTY=90
# TARS_VERBOSITY=50

# ── Wake word ────────────────────────────────────────────
# If TARS_REQUIRE_WAKE_WORD=true, TARS ignores audio that
# doesn't contain the wake word (default: "tars")
TARS_REQUIRE_WAKE_WORD=false
TARS_WAKE_WORD=tars

# ── Dashboard ────────────────────────────────────────────
TARS_DASHBOARD_PORT=8080
TARS_DASHBOARD_HOST=0.0.0.0

# ── PIR wake sensor ───────────────────────────────────────
TARS_PIR_PIN=27
TARS_SLEEP_AFTER=120        # seconds of no motion before sleeping
TARS_PIR_DEBOUNCE=500       # ms

# ── Idle behaviour ────────────────────────────────────────
TARS_IDLE_TIMEOUT=40        # seconds of silence before idle monologue
TARS_IDLE_REPEAT_MIN=30
TARS_IDLE_REPEAT_MAX=90

# ── Proactive alerts ──────────────────────────────────────
TARS_ALERT_POLL=5           # sensor poll interval in seconds
TARS_TEMP_ALERT_C=42        # speak when temp exceeds this
TARS_TEMP_DANGER_C=60       # urgent alert above this
TARS_OBSTACLE_ALERT=20      # speak when obstacle closer than this (cm)
TARS_OBSTACLE_COOLDOWN=15   # seconds between repeated obstacle alerts

# ── Memory ───────────────────────────────────────────────
TARS_MEMORY_FILE=memory.json
TARS_MAX_HISTORY_MESSAGES=40
TARS_MAX_EPISODES=20

# ── AI tuning ────────────────────────────────────────────
TARS_MODEL_HISTORY_WINDOW=12
TARS_AI_MAX_RETRIES=3
